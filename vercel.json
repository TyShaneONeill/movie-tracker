{
  "buildCommand": "node scripts/generate-movie-pages.js && npx expo export --platform web && cp ads.txt dist/ads.txt && cp public/app-ads.txt dist/app-ads.txt",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "missing": [
        { "type": "cookie", "key": "pocketstubs_visited" },
        { "type": "query", "key": "code" },
        { "type": "query", "key": "access_token" }
      ],
      "destination": "/welcome",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/movie/:id",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(bot|facebookexternalhit|facebot|twitterbot|whatsapp|slackbot|discordbot|linkedinbot|telegrambot|applebot|iframely|preview|embed|crawler|spider).*" }],
      "destination": "/api/og?type=movie&id=:id"
    },
    {
      "source": "/tv/:id",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(bot|facebookexternalhit|facebot|twitterbot|whatsapp|slackbot|discordbot|linkedinbot|telegrambot|applebot|iframely|preview|embed|crawler|spider).*" }],
      "destination": "/api/og?type=tv&id=:id"
    },
    { "source": "/ingest/static/:path*", "destination": "https://us-assets.i.posthog.com/static/:path*" },
    { "source": "/ingest/:path*", "destination": "https://us.i.posthog.com/:path*" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
