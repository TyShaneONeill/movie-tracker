{
  "buildCommand": "node scripts/generate-movie-pages.js && npx expo export --platform web && cp ads.txt dist/ads.txt && cp public/app-ads.txt dist/app-ads.txt && node scripts/inject-posthog-snippet.js",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/ig",
      "destination": "/?utm_source=instagram&utm_medium=bio&utm_campaign=bio",
      "permanent": false
    },
    {
      "source": "/th",
      "destination": "/?utm_source=threads&utm_medium=bio&utm_campaign=bio",
      "permanent": false
    },
    {
      "source": "/x",
      "destination": "/?utm_source=twitter&utm_medium=bio&utm_campaign=bio",
      "permanent": false
    },
    {
      "source": "/tt",
      "destination": "/?utm_source=tiktok&utm_medium=bio&utm_campaign=bio",
      "permanent": false
    },
    {
      "source": "/yt",
      "destination": "/?utm_source=youtube&utm_medium=bio&utm_campaign=bio",
      "permanent": false
    },
    {
      "source": "/rd",
      "destination": "/?utm_source=reddit&utm_medium=bio&utm_campaign=bio",
      "permanent": false
    },
    {
      "source": "/dc",
      "destination": "/?utm_source=discord&utm_medium=bio&utm_campaign=bio",
      "permanent": false
    },
    {
      "source": "/",
      "missing": [
        { "type": "cookie", "key": "pocketstubs_visited" },
        { "type": "query", "key": "code" },
        { "type": "query", "key": "access_token" }
      ],
      "destination": "/welcome",
      "permanent": false
    }
  ],
  "functions": {
    "api/og.js": {
      "includeFiles": "dist/index.html"
    }
  },
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/movie/:id",
      "destination": "/api/og?type=movie&id=:id"
    },
    {
      "source": "/tv/:id",
      "destination": "/api/og?type=tv&id=:id"
    },
    { "source": "/ingest/static/:path*/", "destination": "https://us-assets.i.posthog.com/static/:path*" },
    { "source": "/ingest/static/:path*", "destination": "https://us-assets.i.posthog.com/static/:path*" },
    { "source": "/ingest/:path*/", "destination": "https://us.i.posthog.com/:path*" },
    { "source": "/ingest/:path*", "destination": "https://us.i.posthog.com/:path*" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/tv-time-import", "destination": "/tv-time-import.html" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
